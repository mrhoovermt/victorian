# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/victorian"

# Resend (Email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@victoriancasinowhitefish.com"

# Twilio (SMS)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# Admin Auth
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""          # bcrypt hash of the admin password
TOTP_SECRET=""                  # Set after first-login QR scan
ADMIN_NOTIFICATION_EMAIL="admin@victoriancasinowhitefish.com"

# Session
SESSION_SECRET="change-me-to-a-random-64-char-string"

# App
NODE_ENV="production"
NEXT_PUBLIC_SITE_URL="https://victoriancasinowhitefish.com"
